generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int    @id @default(autoincrement())
  fullName                String @map("full_name")
  phone                   String @unique
  role                    Int
  photoTexPassport        Json   @map("photo_tex_passport")
  photoUserPassport       Json   @map("photo_user_passport")
  photoLicense            Json   @map("photo_license")
  photoConfidencePassport Json   @map("photo_confidence_passport")
  photoDriverLicense      Json   @map("photo_driver_license")
  createdAt               Int    @default(0) @map("created_at")
  updatedAt               Int    @default(0) @map("updated_at")
}

model Category {
  id        Int    @id @default(autoincrement())
  title     String
  logo      String
  createdAt Int    @default(0) @map("created_at")
  updatedAt Int    @default(0) @map("updated_at")
}
