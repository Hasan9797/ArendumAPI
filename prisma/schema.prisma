generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  full_name  String
  phone      String   @unique
  role       Int
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
}
